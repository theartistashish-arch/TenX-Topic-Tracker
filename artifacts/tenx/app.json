{
  "expo": {
    "name": "Topter",
    "slug": "topter",
    "version": "1.0.0",
    "icon": "./assets/images/icon.png",
    "scheme": "topter",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e09b92da-09f6-4d12-81f9-7781809548da",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1020"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.topter.app"
    },
    "android": {
      "package": "com.topter.app",
      "googleServicesFile": "google-services.json",
      "softwareKeyboardLayoutMode": "resize",
      "statusBar": {
        "style": "auto",
        "translucent": true,
        "backgroundColor": "#0b1020"
      },
      "navigationBar": {
        "barStyle": "dark-content",
        "backgroundColor": "#0b1020"
      },
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0b1020",
          "defaultChannel": "timer",
          "useNextNotificationsApi": true
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8963042908346749~6094172613",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "delayAppMeasurementInit": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "buildToolsVersion": "35.0.0",
            "ndkVersion": "26.1.10909125",
            "manifestPlaceholders": {
              "android:resizeableActivity": "true"
            }
          },
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "e09b92da-09f6-4d12-81f9-7781809548da"
      }
    }
  }
}
