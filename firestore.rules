rules_version = '2';

// Firestore Security Rules for TenX
//
// HOW TO DEPLOY
// -------------
// 1. Install the Firebase CLI (one-time):
//      npm install -g firebase-tools
//
// 2. Log in and select your project:
//      firebase login
//      firebase use --add          # pick your project ID
//
// 3. Deploy only the Firestore rules (safe, does not touch hosting or functions):
//      firebase deploy --only firestore:rules
//
// IMPORTANT: Never switch Firestore back to test-mode rules
// ("allow read, write: if true") in a production project.
// That would expose every user's profile to any other authenticated user.

service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid}
    // A document may only be read or written by the authenticated user
    // whose UID matches the document ID.  No other user — authenticated
    // or not — can access it.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // users/{uid}/data/{key}
      // Subcollections (topics, settings) must be explicitly covered —
      // rules_version='2' does not cascade parent rules to subcollections.
      match /data/{document} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
